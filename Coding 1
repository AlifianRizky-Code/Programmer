<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Menu Coding</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
      text-align: center;
      margin: 0;
    }

    h1 {
      padding: 20px;
    }

    .menu {
      display: flex;
      justify-content: center;
      gap: 20px;
      flex-wrap: wrap;
      padding: 20px;
    }

    .card {
      background: #1e293b;
      padding: 20px;
      border-radius: 15px;
      width: 200px;
      cursor: pointer;
      transition: 0.3s;
    }

    .card:hover {
      transform: scale(1.05);
      background: #334155;
    }

    #content {
      margin-top: 30px;
      padding: 20px;
      background: #1e293b;
      border-radius: 10px;
      width: 80%;
      margin-left: auto;
      margin-right: auto;
    }
  </style>
</head>
<body>

  <h1>Menu Belajar Coding</h1>

  <div class="menu">
    <div class="card" onclick="showContent('html')">HTML</div>
    <div class="card" onclick="showContent('css')">CSS</div>
    <div class="card" onclick="showContent('js')">JavaScript</div>
    <div class="card" onclick="showContent('python')">Python</div>
  </div>

  <div id="content">Klik menu di atas untuk melihat materi</div>

  <script>
    function showContent(menu) {
      let content = "";

      if (menu === 'html') {
        content = "<h2>HTML</h2><p>HTML digunakan untuk membuat struktur website.</p>";
      } else if (menu === 'css') {
        content = "<h2>CSS</h2><p>CSS digunakan untuk mengatur tampilan website.</p>";
      } else if (menu === 'js') {
        content = "<h2>JavaScript</h2><p>JavaScript membuat website menjadi interaktif.</p>";
      } else if (menu === 'python') {
        content = "<h2>Python</h2><p>Python sering digunakan untuk backend dan AI.</p>";
      }

      document.getElementById("content").innerHTML = content;
    }
  </script>

</body>
</html>
